// Mölkky tournament schema
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TournamentFormat {
  SINGLE_ELIM
  ROUND_ROBIN
  GROUP_KNOCKOUT
}

enum TournamentStatus {
  REGISTRATION
  IN_PROGRESS
  COMPLETED
}

enum MatchStage {
  GROUP
  KNOCKOUT
  ROUND_ROBIN
}

enum MatchStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model Tournament {
  id        String           @id @default(cuid())
  name      String
  format    TournamentFormat
  status    TournamentStatus @default(REGISTRATION)
  // Format settings, e.g. { "groupCount": 2, "advancersPerGroup": 2 }
  settings  Json             @default("{}")
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  players Player[]
  matches Match[]
}

model Player {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  name         String
  seed         Int        @default(0)
  groupName    String?
  createdAt    DateTime   @default(now())

  matchesAsP1 Match[] @relation("MatchPlayer1")
  matchesAsP2 Match[] @relation("MatchPlayer2")
  matchesWon  Match[] @relation("MatchWinner")

  @@index([tournamentId])
}

model Match {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  stage       MatchStage
  round       Int         @default(1)
  matchNumber Int         @default(0)
  groupName   String?

  player1Id String?
  player1   Player? @relation("MatchPlayer1", fields: [player1Id], references: [id], onDelete: SetNull)
  player2Id String?
  player2   Player? @relation("MatchPlayer2", fields: [player2Id], references: [id], onDelete: SetNull)

  player1Score Int?
  player2Score Int?

  winnerId String?
  winner   Player? @relation("MatchWinner", fields: [winnerId], references: [id], onDelete: SetNull)

  status    MatchStatus @default(PENDING)
  judgeName String?

  // Winner advancement (knockout brackets)
  nextMatchId String?
  nextSlot    Int? // 1 or 2

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tournamentId])
  @@index([tournamentId, stage, round])
}
