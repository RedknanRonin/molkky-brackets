# Copy to .env.local and fill in real values.
# The `&schema=molkky` isolates this app in its own Postgres schema (safe to share a DB).
DATABASE_URL="postgres://user:password@host:port/dbname?sslmode=require&schema=molkky"

# Password to create/manage tournaments (organizer)
ADMIN_PASSWORD="set-a-strong-admin-password"

# Shared password judges enter (along with their name) to score matches
JUDGE_PASSWORD="set-a-judge-password"

# Random 64-char hex string for signing auth cookies (openssl rand -hex 32)
SESSION_SECRET="generate-a-random-secret"
